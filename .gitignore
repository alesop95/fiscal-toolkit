# --- Livello privato e ignorato (sezione 6/10 del sistema di progetto) ---

# Note locali, non pubbliche (livello privato e verboso)
_notes/

# Documenti fiscali reali da ingestionare (CU, cedolini, previdenza): contengono dati personali
# e non entrano MAI nel version control. La cartella e' ignorata per intero, tranne il suo README
# tracciato che ne spiega l'uso. Gli output derivati con cifre personali restano sotto _notes/.
/documenti/*
!/documenti/README.md

# Override personali e permessi personali
CLAUDE.local.md
.claude/settings.local.json

# Segreti e materiale di credenziale: mai committati. Il template pubblico e' .env.example,
# tracciato; la copia compilata .env resta locale.
.env
.env.*
!.env.example
*.pem
*.key

# Estratti temporanei di documenti voluminosi (cartelle scratch e cache di doc-ingest)
_notes/.tmp-doc-*/
.tmp-doc-*/

# Documenti Word grezzi (binari). I .pdf sorgente restano versionabili di default; i PDF
# fiscali reali vivono comunque sotto _notes/ e sono gia' ignorati.
*.docx

# --- Ambienti e derivati ---

# Node
node_modules/
dist/

# Python (previsto solo per eventuali script accessori)
.venv/
__pycache__/
*.pyc

# Editor / OS
.vscode/
.DS_Store
Thumbs.db
